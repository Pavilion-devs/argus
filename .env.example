# Copy to .env and fill in. NEVER commit .env.

# --- Claude / Anthropic (agent reasoning brain) ---
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx
ARGUS_MODEL=claude-sonnet-4-6

# Provider: "anthropic" (direct API, uses ANTHROPIC_API_KEY) or "bedrock" (AWS).
ARGUS_PROVIDER=anthropic
# For bedrock: a Bedrock API key (bearer token) + region with Anthropic model access.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-west-2

# --- Splunk MCP Server ---
# The MCP endpoint lives on the Splunk management port.
SPLUNK_MCP_URL=https://localhost:8089/services/mcp
# Bearer token created in Splunk: Settings > Tokens (enable token auth first).
SPLUNK_TOKEN=
# Self-signed dev cert -> don't verify TLS locally.
SPLUNK_VERIFY_SSL=false

# --- Splunk (docker) ---
SPLUNK_PASSWORD=Changeme123!

# --- Optional: real threat-intel enrichment ---
# VT_API_KEY=
# ABUSEIPDB_API_KEY=

# --- Optional: real response connectors ---
# SLACK_WEBHOOK_URL=
# JIRA_BASE_URL=
